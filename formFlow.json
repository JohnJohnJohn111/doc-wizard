{
  "templates": [
    {
      "id": "shelf-company",
      "name": "Shelf Company Generator",
      "description": "Generate corporate documentation for a new shelf company"
    }
  ],
  "flows": {
    "shelf-company": {
      "startQuestion": "q1",
      "questions": {
        "q1": {
          "id": "q1",
          "field": "entity_name",
          "label": "Name of the new entity",
          "type": "text",
          "placeholder": "e.g. Acme Holdings AB",
          "required": true,
          "next": "q2"
        },
        "q2": {
          "id": "q2",
          "field": "address",
          "label": "Address",
          "type": "textarea",
          "placeholder": "e.g. Storgatan 1, 111 23 Stockholm, Sweden",
          "required": true,
          "next": "q3"
        },
        "q3": {
          "id": "q3",
          "field": "accounting_year",
          "label": "Accounting year",
          "type": "text",
          "placeholder": "e.g. 1 Jan – 31 Dec",
          "required": true,
          "next": "q4"
        },
        "q4": {
          "id": "q4",
          "field": "business",
          "label": "Business of the company",
          "type": "textarea",
          "placeholder": "e.g. Owning and managing real property and chattels",
          "required": true,
          "next": "q5"
        },
        "q5": {
          "id": "q5",
          "field": "share_capital",
          "label": "Share capital",
          "type": "text",
          "placeholder": "e.g. SEK 25,000 or EUR 3,000",
          "required": true,
          "next": "q6"
        },
        "q6": {
          "id": "q6",
          "field": "shareholders",
          "label": "Shareholder(s)",
          "type": "textarea",
          "placeholder": "e.g. John Smith (100 shares), Jane Doe (100 shares)",
          "required": true,
          "next": "q7"
        },
        "q7": {
          "id": "q7",
          "field": "email",
          "label": "E-mail address for the company",
          "hint": "Not mandatory — only if you want to register a publicly available contact e-mail for the company.",
          "type": "text",
          "placeholder": "e.g. info@company.com",
          "required": false,
          "next": "q8"
        },
        "q8": {
          "id": "q8",
          "field": "clauses",
          "label": "Please select the applicable provisions",
          "type": "checkbox",
          "options": [
            "Pre-emption clause",
            "Consent clause",
            "Right of first refusal clause",
            "Issue original share certificates"
          ],
          "required": false,
          "next": "q9"
        },
        "q9": {
          "id": "q9",
          "field": "board_members",
          "label": "Board members",
          "type": "people",
          "fields": ["Full name", "Date of birth / Social security number", "Address", "Nationality", "Chairman"],
          "chairmanField": true,
          "required": true,
          "next": "q10"
        },
        "q10": {
          "id": "q10",
          "field": "deputy_board_members",
          "label": "Deputy board members",
          "hint": "Leave empty if none.",
          "type": "people",
          "fields": ["Full name", "Date of birth / Social security number", "Address", "Nationality"],
          "chairmanField": false,
          "required": false,
          "next": "q11"
        },
        "q11": {
          "id": "q11",
          "field": "managing_director",
          "label": "Managing director (if appointed)",
          "hint": "Leave empty if not applicable.",
          "type": "people",
          "fields": ["Full name", "Date of birth / Social security number", "Address", "Nationality"],
          "chairmanField": false,
          "required": false,
          "next": "q12"
        },
        "q12": {
          "id": "q12",
          "field": "authorized_signatory",
          "label": "Authorized signatory",
          "type": "text",
          "placeholder": "e.g. Two board members acting jointly",
          "required": true,
          "next": "q13"
        },
        "q13": {
          "id": "q13",
          "field": "auditor",
          "label": "Auditor, including auditor in charge",
          "type": "textarea",
          "placeholder": "e.g. Ernst & Young AB, auditor in charge: Anna Svensson",
          "required": false,
          "next": null
        }
      }
    }
  }
}
